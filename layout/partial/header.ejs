<header class="site-header">
  <div class="header-inner">
    <a class="site-title" href="<%- url_for('/') %>"><%= config.title %></a>
    <nav class="site-nav">
      <% for (var name in theme.menu) { %>
        <a class="nav-link" href="<%- url_for(theme.menu[name]) %>"><%= name %></a>
      <% } %>
    </nav>
  </div>
</header>
